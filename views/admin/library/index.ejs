<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Library Admin – SBU</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .lib-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
    .btn-add { padding: .55rem 1.2rem; background: #2d5a27; color: #fff; border: none; border-radius: 7px; font-size: .88rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: background .2s; }
    .btn-add:hover { background: #5a8a4a; }
    .search-bar { margin-bottom: 1.25rem; }
    .search-bar input { padding: .5rem .9rem; border: 1px solid #ddd; border-radius: 7px; font-size: .88rem; width: 280px; }
    .lib-table { width: 100%; border-collapse: collapse; font-size: .88rem; }
    .lib-table th { background: #f5f0e8; padding: .7rem 1rem; text-align: left; font-size: .75rem; letter-spacing: .08em; text-transform: uppercase; color: #666; border-bottom: 2px solid #e8dcc8; }
    .lib-table td { padding: .75rem 1rem; border-bottom: 1px solid #eee; vertical-align: middle; }
    .lib-table tr:hover td { background: #fafafa; }
    .type-badge { font-size: .68rem; padding: .2rem .5rem; border-radius: 4px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; }
    .type-badge.book    { background: #e8f5e9; color: #2e7d32; }
    .type-badge.journal { background: #e3f2fd; color: #1565c0; }
    .type-badge.report  { background: #fff3e0; color: #e65100; }
    .type-badge.blog    { background: #f3e5f5; color: #6a1b9a; }
    .avail-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: .4rem; }
    .avail-dot.full       { background: #5a8a4a; }
    .avail-dot.preview    { background: #c8a84b; }
    .avail-dot.restricted { background: #c0392b; }
    .action-btns { display: flex; gap: .4rem; }
    .btn-edit   { padding: .3rem .7rem; background: #e3f2fd; color: #1565c0; border: none; border-radius: 5px; font-size: .78rem; text-decoration: none; cursor: pointer; }
    .btn-delete { padding: .3rem .7rem; background: #ffebee; color: #c62828; border: none; border-radius: 5px; font-size: .78rem; cursor: pointer; }
    .btn-delete:hover { background: #ffcdd2; }
    .btn-edit:hover { background: #bbdefb; }
    .stat-chips { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .stat-chip { background: #fff; border: 1px solid #ddd; border-radius: 9px; padding: .6rem 1rem; font-size: .85rem; }
    .stat-chip strong { display: block; font-size: 1.3rem; font-weight: 700; color: #2d5a27; }
    .empty-row td { text-align: center; color: #aaa; padding: 2rem; font-style: italic; }
    .pagination { display: flex; gap: .4rem; margin-top: 1.25rem; }
    .pag-btn { padding: .35rem .75rem; border: 1px solid #ddd; border-radius: 6px; background: #fff; color: #333; font-size: .83rem; text-decoration: none; }
    .pag-btn.active { background: #2d5a27; border-color: #2d5a27; color: #fff; }
    .pag-btn.disabled { opacity: .35; pointer-events: none; }
    .truncate { max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  </style>
</head>
<body>
<div class="app">
  <!-- Sidebar (matching existing admin layout) -->
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/library" class="active">Library</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header">
      <h1>Library Manager</h1>
    </header>

    <section class="card">
      <div class="lib-header">
        <div>
          <h2>All Library Items</h2>
          <p style="font-size:.82rem;color:#888;margin-top:.25rem"><%= total %> total items</p>
        </div>
        <a href="/admin/library/add" class="btn-add">+ Add New Item</a>
      </div>

      <div class="search-bar">
        <form method="GET" action="/admin/library">
          <input type="text" name="q" placeholder="Quick search…" value="">
        </form>
      </div>

      <div style="overflow-x:auto">
        <table class="lib-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Author</th>
              <th>Category</th>
              <th>Type</th>
              <th>Format</th>
              <th>Availability</th>
              <th>Views</th>
              <th>Added</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (items.length === 0) { %>
              <tr class="empty-row"><td colspan="9">No library items yet. <a href="/admin/library/add">Add one →</a></td></tr>
            <% } %>
            <% items.forEach(item => { %>
              <tr>
                <td>
                  <div class="truncate" title="<%= item.title %>">
                    <a href="/library/<%= item._id %>" target="_blank" style="color:#1a1a2e;text-decoration:none;font-weight:500"><%= item.title %></a>
                  </div>
                </td>
                <td><%= item.author || '—' %></td>
                <td><%= item.category %></td>
                <td><span class="type-badge <%= item.documentType %>"><%= item.documentType %></span></td>
                <td><%= item.fileFormat || '—' %></td>
                <td>
                  <span class="avail-dot <%= item.availability %>"></span><%= item.availability %>
                </td>
                <td><%= item.views %></td>
                <td><%= new Date(item.createdAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></td>
                <td>
                  <div class="action-btns">
                    <a href="/admin/library/edit/<%= item._id %>" class="btn-edit">Edit</a>
                    <form method="POST" action="/admin/library/delete/<%= item._id %>" onsubmit="return confirm('Delete this item?')">
                      <button type="submit" class="btn-delete">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <a href="?page=<%= page - 1 %>" class="pag-btn <%= page <= 1 ? 'disabled' : '' %>">‹</a>
          <% for (let p = 1; p <= totalPages; p++) { %>
            <a href="?page=<%= p %>" class="pag-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
          <% } %>
          <a href="?page=<%= page + 1 %>" class="pag-btn <%= page >= totalPages ? 'disabled' : '' %>">›</a>
        </div>
      <% } %>
    </section>
  </main>
</div>
</body>
</html>
