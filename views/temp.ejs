<section class="about-section">
  <div class="wrapper">
    <div class="about-grid">

      <!-- LEFT -->
      <div class="about-photo">

        <div id="aboutCarousel"
             class="carousel slide"
             data-bs-ride="carousel"
             data-bs-interval="2500"
             data-bs-pause="false">

          <div class="carousel-inner">

            <% if (about?.images && about.images.length > 0) { %>

              <% about.images.forEach((img, index) => { %>
                <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                  <img src="<%= img.trim() %>" class="d-block w-100">
                </div>
              <% }) %>

            <% } else { %>

              <div class="carousel-item active">
                <img src="https://picsum.photos/500/300">
              </div>

            <% } %>

          </div>

          <!-- controls -->
          <button class="carousel-control-prev" type="button" data-bs-target="#aboutCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>

          <button class="carousel-control-next" type="button" data-bs-target="#aboutCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>

        </div>

      </div>

      <!-- RIGHT -->
      <div class="about-card">
        <h3><%= about?.title || "ABOUT US" %></h3>
        <p><%= about?.description || "We are committed to sustainability." %></p>
      </div>

    </div>
  </div>
</section>




<div class="col-card-illustration">
<% if (colCard?.images && colCard.images.length > 0) { %>

<div id="colCarousel" class="carousel slide">
  <div class="carousel-inner">

    <% colCard.images.forEach((img, index) => { %>
      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
        <img src="<%= img %>" class="d-block w-100" style="height:260px; object-fit:cover;">
      </div>
    <% }) %>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#colCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#colCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>

<% } else { %>
  <div class="placeholder">
    Illustration / people graphic
  </div>
<% } %>
            </div>



              <section id="events" class="section section-gray">
        <div class="section-inner two-column">
          <!-- Left -->
          <div class="col-card">
            <div class="megaphone-icon">
              <i class="fa-solid fa-bullhorn"></i>
            </div>
            <!-- <div class="label-pill">Circular Economy</div>
            <h2>WHO'S COMING TO TOWN?</h2> -->
            <div class="label-pill">
  <%= colCard?.label || "Circular Economy" %>
</div>

<h2>
  <%= colCard?.heading || "WHO'S COMING TO TOWN?" %>
</h2>

<p>
  <%= colCard?.description || "Stay updated with our latest events" %>
</p>


<div class="col-card-illustration">

  <% if (colCard?.images && colCard.images.length > 0) { %>

    <img src="<%= colCard.images[0] %>" 
         alt="col-card image"
         style="width:100%; border-radius:8px; object-fit:cover; height:250px;" />

  <% } else { %>

    <div class="placeholder">
      Illustration / people graphic
    </div>

  <% } %>

</div>
            
          </div>

          <!-- Right -->
          <div class="events-panel">
            <h3>Upcoming Acts</h3>
            <div class="events-panel-sub">WHO'S COMING TO TOWN?</div>

            <div class="events-list">
              <% if (!events || events.length === 0) { %>
              <p>No upcoming events</p>
              <% } %>

              <% events.forEach(event => { %>
              <div class="event-row">
                <div class="event-info">
                  <div class="date">
                    <%= event.date.toDateString() %> • <%= event.time %>
                  </div>

                  <div class="topic">
                    <%= event.title %>
                  </div>

                  <div class="artists">
                    <strong>Speakers:</strong> <%= event.artists %>
                  </div>

                  <div class="location">
                    <strong>Location:</strong> <%= event.location %>
                  </div>
                </div>

                <button class="btn-light">Buy Tickets</button>
              </div>
              <% }) %>
            </div>

            <button class="btn-light btn-block">SEE ALL EVENTS</button>
          </div>
        </div>
      </section>


          <header>

        <div class="wrapper nav">
          <div class="nav-left">
            <!-- <div class="logo-mark">SB</div>
        <div class="logo-text">
          <span>sustainable</span>
          <span>business union</span>
        </div> -->
            <div class="logo-mark">
              <%= logo.logoMark %>
            </div>

            <div class="logo-text">
              <span><%= logo.logoTextTop %></span>
              <span><%= logo.logoTextBottom %></span>
            </div>
          </div>

          <nav class="nav-center">
            <a href="#home">Home</a>
            <a href="#info">Info</a>
            <a href="#events">Events</a>
            <a href="/contact">Contact</a>
          </nav>

          <div class="nav-right">
            <div class="social-links">

            </div>

          </div>
        </div>
      </header>




