<!DOCTYPE html>
<html>
<head>
  <title>Edit Event</title>
  <link rel="stylesheet" href="/style.css" /> 
</head>
<body>
  <!-- this page is for updatingor deleting the event -->

<h2>Edit Event</h2>

<form method="POST" action="/updateEvent/<%= event._id %>">

  <input type="text" name="title" value="<%= event.title %>" required />
  <input type="text" name="artists" value="<%= event.artists %>" required />
  <input type="date" name="date" value="<%= event.date.toISOString().split('T')[0] %>" required />
  <input type="time" name="time" value="<%= event.time %>" required />
  <input type="text" name="location" value="<%= event.location %>" required />

  <button type="submit">Update Event</button>

</form>

</body>
</html>